[gd_resource type="Resource" script_class="ComboNode" load_steps=20 format=3]

[ext_resource type="Script" path="res://scripts/data/ComboNode.gd" id="1_combonode"]
[ext_resource type="Resource" path="res://resources/attacks/punch_light.tres" id="2_punch_light"]
[ext_resource type="Resource" path="res://resources/attacks/punch_heavy.tres" id="3_punch_heavy"]
[ext_resource type="Resource" path="res://resources/attacks/kick_light.tres" id="4_kick_light"]
[ext_resource type="Resource" path="res://resources/attacks/kick_heavy.tres" id="5_kick_heavy"]

; ============================================================
; 3ヒット目（エンダー）ノード群 - branches なし
; ============================================================

[sub_resource type="Resource" id="ComboNode_PPP"]
script = ExtResource("1_combonode")
attack_data = ExtResource("5_kick_heavy")
branches = {}
hit_count = 3
is_ender = true
ender_damage_multiplier = 1.3
window_frames = 30

