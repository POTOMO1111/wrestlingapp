; ============================================================
; ROOT ノード（このファイルのメインリソース）
; attack_data = null, branches で P/K の1ヒット目へ分岐
; ============================================================

[resource]
script = ExtResource("1_combonode")
attack_data = null
branches = {"PUNCH": SubResource("ComboNode_P"), "KICK": SubResource("ComboNode_K")}
